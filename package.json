{
  "name": "thoughtflow-api",
  "version": "0.1.0",
  "description": "ThoughtFlow backend API — auth, capture, AI pipeline, and data management",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "migrate:up": "node-pg-migrate up --migrations-dir src/database/migrations --migration-file-language ts",
    "migrate:down": "node-pg-migrate down --migrations-dir src/database/migrations --migration-file-language ts",
    "migrate:create": "node-pg-migrate create --migrations-dir src/database/migrations --migration-file-language ts",
    "db:seed": "ts-node src/database/seeds/run.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1056.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-pg-migrate": "^7.0.0",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/ioredis-mock": "^8.2.7",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
