{
  "name": "thoughtflow-api",
  "version": "0.1.0",
  "description": "ThoughtFlow API - Voice-driven thought capture with AI categorization",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn src/server.ts",
    "lint": "eslint src/ --ext .ts",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "migrate:up": "node-pg-migrate up --migrations-dir src/database/migrations --migration-file-language ts",
    "migrate:down": "node-pg-migrate down --migrations-dir src/database/migrations --migration-file-language ts",
    "migrate:create": "node-pg-migrate create --migrations-dir src/database/migrations --migration-file-language ts",
    "db:seed": "ts-node src/database/seeds/run.ts"
  },
  "dependencies": {
    "pg": "^8.12.0",
    "node-pg-migrate": "^7.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
