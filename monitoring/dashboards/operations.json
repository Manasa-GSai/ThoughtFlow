{
  "uid": "thoughtflow-operations",
  "title": "ThoughtFlow — Operations (RED + Infrastructure)",
  "description": "Operations SLI dashboard for WO-006: RED method (Rate, Errors, Duration) per HTTP endpoint plus PostgreSQL connection-pool and query-latency health. Backs the 99.5% uptime SLA and the <200ms p95 non-AI latency budget (NFR-1).",
  "tags": ["thoughtflow", "sli", "operations", "wo-006"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (route) (rate(http_requests_total[5m]))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (5xx %)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.05 }] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
          "legendFormat": "5xx error rate"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 Latency — non-AI routes (SLO 200ms, alert 500ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{route!~\".*/(transcribe|categorize).*\"}[5m])))",
          "legendFormat": "{{route}} p95"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Connections (in-flight)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "expr": "active_connections",
          "legendFormat": "in-flight requests"
        }
      ]
    },
    {
      "id": 5,
      "title": "PostgreSQL Pool Utilization",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "expr": "db_pool_active_connections",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "db_pool_idle_connections",
          "legendFormat": "idle"
        }
      ]
    },
    {
      "id": 6,
      "title": "PostgreSQL Query p95 Duration",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}} p95"
        }
      ]
    }
  ]
}
